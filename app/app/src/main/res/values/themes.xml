<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark-only, no action bar. All UI is Compose; system bars are drawn
         edge-to-edge with the app's #0F0F11 background. -->
    <style name="Theme.FitTrack" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/ft_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
    </style>
</resources>
